# env.linux.example — modèle de configuration Linux (Fedora).
#
# Nommé "env.linux.example" (et non ".env.linux.example") car les noms en .env*
# sont protégés en écriture. Sur Fedora : copier vers core/.env puis ajuster.
# Ne jamais committer le .env réel.
#
# Topologie canonique = single-host en localhost (127.0.0.1) : le backend joint
# Ollama / SearXNG / ComfyUI sur 127.0.0.1. (L'ancienne topologie VM Hyper-V est
# archivée sous infra/vm/, hors runtime canonique.)

PROJECT_NAME=ai_assistant_core

OPENWEBUI_PORT=8088
SEARXNG_PORT=8081
OLLAMA_PORT=12000

# URLs Docker-internes (services compose)
OLLAMA_BASE_URL=http://ollama:11434
SEARXNG_BASE_URL=http://searxng:8080

# URLs runtime côté backend Python — topologie single-host Fedora (localhost).
# Ollama est exposé par compose sur 127.0.0.1:${OLLAMA_PORT} -> conteneur 11434.
OLLAMA_URL=http://127.0.0.1:12000/api/generate
OLLAMA_TAGS_URL=http://127.0.0.1:12000/api/tags
SEARXNG_SEARCH_URL=http://127.0.0.1:8081/search
COMFYUI_URL=http://127.0.0.1:8188

OLLAMA_DATA_PATH=../data/ollama
OPENWEBUI_DATA_PATH=../data/openwebui
SEARXNG_CONFIG_PATH=./searxng

# À remplacer dans le vrai .env
WEBUI_SECRET_KEY=change-me
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# ComfyUI : sous Linux, COMFYUI_BAT_PATH pointe vers le lanceur shell (.sh) de ComfyUI.
# Les lanceurs sont désormais cross-platform (cmd /c sous Windows, bash <script> sous Linux).
# Laisser vide + AUTO_START=false par défaut (ComfyUI traité comme service déjà joignable).
COMFYUI_BAT_PATH=
COMFYUI_AUTO_START=false
COMFYUI_START_TIMEOUT=120
COMFYUI_OUTPUT_DIR=

COMFYUI_CHECKPOINT_NAME=realvisxlV50_v50Bakedvae.safetensors
COMFYUI_DEFAULT_WORKFLOW=object_basic_v1

# Qualité par requête (draft/final). Le mode final ajoute un étage refiner
# (deux-étages base->refiner) puis une passe hires ESRGAN. Le checkpoint refiner
# et le modèle d'upscale doivent exister dans l'installation ComfyUI.
# - refiner : second checkpoint chargé pour l'étage de raffinement
# - upscale model : fichier ESRGAN dans ComfyUI/models/upscale_models/
COMFYUI_REFINER_CHECKPOINT_NAME=realvisxlV50_v50Bakedvae.safetensors
COMFYUI_UPSCALE_MODEL_NAME=4x-UltraSharp.pth
