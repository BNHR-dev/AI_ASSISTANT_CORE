# Configuration de la stack Docker (cross-platform).
# Copier en `.env.docker` et ajuster si besoin. Réseau = NOMS DE SERVICE compose.

# --- Services internes (résolus par le réseau compose) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_TAGS_URL=http://ollama:11434/api/tags
SEARXNG_SEARCH_URL=http://searxng:8080/search
COMFYUI_URL=http://comfyui:8188

# --- ComfyUI : modes draft/final (démo pleine) — exercé en P2 ---
COMFYUI_AUTO_START=false
COMFYUI_OUTPUT_DIR=/outputs/comfyui
COMFYUI_CHECKPOINT_NAME=realvisxlV50_v50Bakedvae.safetensors
COMFYUI_REFINER_CHECKPOINT_NAME=realvisxlV50_v50Bakedvae.safetensors
COMFYUI_UPSCALE_MODEL_NAME=4x-UltraSharp.pth

# --- Blender : couche rendu — ajoutée en P1b ---
BLENDER_EXE=/usr/local/bin/blender
BLENDER_OUTPUT_DIR=/outputs/blender
# Démo : le conteneur isole déjà ; durcissement via bwrap imbriqué (caps requises).
AAC_BLENDER_SANDBOX=auto
