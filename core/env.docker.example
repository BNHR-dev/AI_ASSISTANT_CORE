# Surcharges optionnelles de la stack Docker. La démo marche SANS ce fichier (les
# défauts sont dans docker-compose.app.yml). Copier en `.env` (chargé automatiquement
# par docker compose) pour surcharger. Réseau interne = noms de service compose.

# --- Services internes (résolus par le réseau compose) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_TAGS_URL=http://ollama:11434/api/tags
SEARXNG_SEARCH_URL=http://searxng:8080/search
COMFYUI_URL=http://comfyui:8188

# --- ComfyUI : modes draft/final (démo pleine) — conteneurisé en P2 ---
COMFYUI_AUTO_START=false
COMFYUI_OUTPUT_DIR=/outputs/comfyui
# Modèles téléchargés par `make fetch-models` (HuggingFace). Surcharge possible si
# vous avez déjà ces modèles ailleurs (mettez alors leurs noms de fichiers).
COMFYUI_CHECKPOINT_NAME=RealVisXL_V5.0_fp16.safetensors
COMFYUI_REFINER_CHECKPOINT_NAME=RealVisXL_V5.0_fp16.safetensors
COMFYUI_UPSCALE_MODEL_NAME=4x-UltraSharp.pth
# Dossier des modèles monté en lecture seule. Défaut ./models (rempli par fetch-models).
# Pour réutiliser des modèles existants, pointez ici (ex. ~/projects/ComfyUI/models).
COMFYUI_MODELS_DIR=./models

# Registre ComfyUI (un dossier par run dans core/outputs/comfyui/<id>/ : image +
# manifest.json). AAC_HOST_OS : OS hôte réel à renseigner sur Windows/macOS (le
# conteneur backend est toujours Linux). Vide -> repli sur la plateforme du conteneur.
AAC_HOST_OS=
# UID/GID hôte : les sorties t'appartiennent (le backend root les chown). Défaut 1000.
AAC_UID=
AAC_GID=

# --- Blender : couche rendu — ajoutée en P1b ---
BLENDER_EXE=/usr/local/bin/blender
BLENDER_OUTPUT_DIR=/outputs/blender
# Démo : le conteneur isole déjà ; durcissement via bwrap imbriqué (caps requises).
AAC_BLENDER_SANDBOX=auto
