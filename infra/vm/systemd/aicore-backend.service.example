[Unit]
Description=AI_ASSISTANT_CORE backend
After=network.target

[Service]
Type=simple
User=bnhr
WorkingDirectory=/home/bnhr/aicore/projects/core
EnvironmentFile=/home/bnhr/aicore/projects/core/.env
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target