PROJECT_NAME=ai_assistant_core

OPENWEBUI_PORT=8088
SEARXNG_PORT=8081
OLLAMA_PORT=12000

# Docker-internal URLs used by compose services on the host workspace
OLLAMA_BASE_URL=http://ollama:11434
SEARXNG_BASE_URL=http://searxng:8080

# Backend -> service URLs. Canonical target = single-host on localhost (127.0.0.1).
# Identical on Linux and Windows: Docker Desktop publishes container ports to
# 127.0.0.1 on both. (The legacy Hyper-V VM topology is archived under infra/vm/
# and is NOT part of the canonical runtime path.)
OLLAMA_URL=http://127.0.0.1:12000/api/generate
OLLAMA_TAGS_URL=http://127.0.0.1:12000/api/tags
SEARXNG_SEARCH_URL=http://127.0.0.1:8081/search
COMFYUI_URL=http://127.0.0.1:8188

OLLAMA_DATA_PATH=../data/ollama
OPENWEBUI_DATA_PATH=../data/openwebui
SEARXNG_CONFIG_PATH=./searxng

# Replace in real .env
WEBUI_SECRET_KEY=change-me
# GPU passthrough: native on Linux (nvidia-container-toolkit); on Windows it
# requires Docker Desktop with the WSL2 backend + the NVIDIA driver.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# ComfyUI is treated as an already reachable service by default.
# Leave autostart disabled unless you intentionally configure a local launcher.
# COMFYUI_BAT_PATH points to the launcher script: a .sh on Linux, a .bat on Windows.
COMFYUI_BAT_PATH=
COMFYUI_AUTO_START=false
COMFYUI_START_TIMEOUT=120
COMFYUI_OUTPUT_DIR=

COMFYUI_CHECKPOINT_NAME=RealVisXL_V5.0_fp16.safetensors
COMFYUI_DEFAULT_WORKFLOW=object_basic_v1

# Per-request quality (draft/final). The "final" mode adds a refiner stage
# (two-stage base->refiner) followed by an ESRGAN hires pass. Both the refiner
# checkpoint and the upscale model must exist in the ComfyUI install.
COMFYUI_REFINER_CHECKPOINT_NAME=RealVisXL_V5.0_fp16.safetensors
COMFYUI_UPSCALE_MODEL_NAME=4x-UltraSharp.pth

# Models dir (filled by `make fetch-models`). Point elsewhere to reuse existing models.
COMFYUI_MODELS_DIR=docker/models

# --- 3D pipeline (Blender) ---
# Blender binary on the host (native runtime; the Docker image ships its own).
BLENDER_EXE=
# Sandbox for generated bpy code: auto | require (fail closed, recommended once exposed
# on a network) | off. `require` needs the `bubblewrap` package (bootstrap.sh installs it).
AAC_BLENDER_SANDBOX=auto

# --- Console / API (bearer token) ---
# off = no auth (LOCAL DEV ONLY). Once exposed: AAC_API_AUTH_MODE=required + a strong
# token in core/.env (never committed). Keep AAC_API_TOKEN EMPTY in this template.
AAC_API_AUTH_MODE=off
AAC_API_TOKEN=